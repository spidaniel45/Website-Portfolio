APP_NAME="Portfolio_Daniel"
APP_ENV=local
APP_DEBUG=true
APP_URL=

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=portfolio_daniel
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# SECONDARY DATABASE (Student Profile)
# ============================================================
DB_STUDENT_CONNECTION=mysql
DB_STUDENT_HOST=127.0.0.1
DB_STUDENT_PORT=3306
DB_STUDENT_DATABASE=studentprofile
DB_STUDENT_USERNAME=root
DB_STUDENT_PASSWORD=

# ============================================================
# FILE UPLOAD CONFIG
# ============================================================
UPLOAD_DIR=uploads/
SCREENSHOT_DIR=project_screenshots/
